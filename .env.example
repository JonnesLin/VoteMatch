# VoteMatch — Production Environment Variables
# Copy to .env and fill in values

# Database — Neon, Supabase, Vercel Postgres, or any PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/votematch?sslmode=require"

# Redis — Upstash, Vercel KV, or any Redis
REDIS_URL="redis://default:password@host:6379"

# Gemini API — for data pipeline LLM operations
GEMINI_API_KEY="your-gemini-api-key"

# Auth — generate with: openssl rand -base64 32
JWT_SECRET="generate-a-random-secret-here"
